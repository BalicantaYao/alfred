# 從 LINE Developers Console 取得 (https://developers.line.biz/console/)
# Messaging API channel > Basic settings > Channel secret
LINE_CHANNEL_SECRET=your_channel_secret

# Messaging API channel > Messaging API > Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# 本機開發用,Railway 會自動注入 PORT
PORT=3000

# (選填) 啟用 LLM 自由格式解析,Claude 和 Gemini 擇一設定即可(兩個都沒設就只支援精確指令)
# Claude:從 https://platform.claude.com/ 取得
ANTHROPIC_API_KEY=your_anthropic_api_key
# Gemini:從 https://aistudio.google.com/ 免費取得
# GEMINI_API_KEY=your_gemini_api_key

# (選填) 兩個 key 都設定時,用 LLM_PROVIDER 指定要用哪個(claude 或 gemini,預設 claude)
# LLM_PROVIDER=gemini

# (選填) 解析用的模型
# ANTHROPIC_MODEL=claude-opus-4-8
# GEMINI_MODEL=gemini-3.5-flash

# (選填,正式環境建議) PostgreSQL 連線字串。沒設定時清單存在本機 data/shopping-lists.json
# Railway 上請在 Variables 設 DATABASE_URL = ${{Postgres.DATABASE_URL}}
# DATABASE_URL=postgres://user:password@host:5432/dbname

# (選填) Google Calendar 每日行程提醒,設定方式見 README「Google Calendar 每日行程提醒」
# 服務帳戶金鑰 JSON(建議 base64:base64 -w0 key.json)
# GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_service_account_key
# 行事曆 ID,個人主行事曆就是你的 Gmail 地址
# GOOGLE_CALENDAR_ID=you@gmail.com
# 推播對象的 LINE ID(對 Bot 輸入「id」可查);沒設定就不會每日推播
# REMINDER_TO=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 每天推播時間與時區
# REMINDER_TIME=08:00
# REMINDER_TZ=Asia/Taipei
